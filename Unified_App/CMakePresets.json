{
  "version": 4,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },
    { "name": "macos", "inherits": "base" },
    { "name": "linux", "inherits": "base" },
    {
      "name": "appimage",
      "inherits": "base",
      "cacheVariables": {
        "LABRADOR_STATIC_LIBUSB": "ON",
        "LABRADOR_STATIC_RUNTIME": "ON"
      }
    },
    {
      "name": "pi",
      "inherits": "base",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release", "LABRADOR_GLES2": "ON" }
    },
    {
      "name": "windows",
      "inherits": "base",
      "cacheVariables": { "LABRADOR_STATIC_LIBUSB": "ON" }
    },
    {
      "name": "windows32",
      "inherits": "windows"
    },
    {
      "name": "debug",
      "inherits": "base",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    }
  ],
  "buildPresets": [
    { "name": "macos", "configurePreset": "macos" },
    { "name": "linux", "configurePreset": "linux" },
    { "name": "appimage", "configurePreset": "appimage" },
    { "name": "pi", "configurePreset": "pi" },
    { "name": "windows", "configurePreset": "windows" },
    { "name": "windows32", "configurePreset": "windows32" },
    { "name": "debug", "configurePreset": "debug" }
  ]
}
